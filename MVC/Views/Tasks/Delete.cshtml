@model StudentTaskTrackerMVC.Services.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<h2>Delete Task</h2>

<h4>Are you sure you want to delete this task?</h4>

<div class="mb-3">
    <strong>Title:</strong> @Model.Title
</div>

<div class="mb-3">
    <strong>Description:</strong> @Model.Description
</div>

<div class="mb-3">
    <strong>Status:</strong> @Model.Status
</div>

<div class="mb-3">
    <strong>Priority:</strong> @Model.Priority
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TaskItemId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>