@model StudentTaskTrackerMVC.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>Total Tasks</h5>
                <h2>@Model.TotalTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>Completed</h5>
                <h2>@Model.CompletedTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>Pending</h5>
                <h2>@Model.PendingTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <h5>In Progress</h5>
                <h2>@Model.InProgressTasks</h2>
            </div>
        </div>
    </div>
</div>